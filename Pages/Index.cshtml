@page
@model PanelDeControl.Pages.IndexModel

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Panel de enlaces</h1>
  <a class="btn btn-primary" href="/Create">Añadir enlace</a>
</div>

<form method="get" class="mb-3">
  <div class="input-group">
    <input name="q" value="@Model.Q" class="form-control" placeholder="Buscar..." />
    <input name="category" value="@Model.Category" class="form-control" placeholder="Categoría" />
    <button class="btn btn-outline-primary">Buscar</button>
  </div>
</form>

<div class="row">
  @foreach(var l in Model.Links)
  {
    <div class="col-md-4 mb-3">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title">
            <a href="@l.Url" target="_blank" rel="noopener">@l.Title</a>
            @if(l.IsFavorite) { <span class="badge bg-warning text-dark">Favorito</span> }
          </h5>
          <p class="card-text">@l.Description</p>
        </div>
        <div class="card-footer text-muted small">
          @l.Category @if(!string.IsNullOrWhiteSpace(l.Tags)) { <span>— @l.Tags</span> }
        </div>
      </div>
    </div>
  }
</div>
