@page
@model PanelDeControl.Pages.IndexModel

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>Panel de enlaces</h1>
  <a class="btn btn-primary" href="/Create">Añadir enlace</a>
</div>

<form method="get" class="mb-3">
  <div class="input-group">
    <input name="q" class="form-control" placeholder="Buscar..." />
    <input name="category" class="form-control" placeholder="Categoría" />
    <button class="btn btn-outline-primary">Buscar</button>
  </div>
</form>

<div class="row">
  @foreach(var l in Model.Links)
  {
    <div class="col-md-4 mb-3">
      <div class="card h-100">
        <div class="card-body d-flex flex-column">
          <h5 class="card-title mb-2">
            <a href="@l.Url" target="_blank" rel="noopener noreferrer">@l.Title</a>
            @if(l.IsFavorite) { <span class="badge bg-warning text-dark ms-2">Favorito</span> }
          </h5>
          <p class="card-text flex-grow-1">@l.Description</p>
          <div>
            <small class="text-muted">@l.Category</small>
            @if(!string.IsNullOrWhiteSpace(l.Tags)) {
              <span class="text-muted"> — @l.Tags</span>
            }
          </div>
        </div>
      </div>
    </div>
  }
</div>
